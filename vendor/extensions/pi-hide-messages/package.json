{
  "name": "pi-hide-messages",
  "version": "0.1.1",
  "description": "Pi extension for hiding older TUI chat history while preserving full session context, with /hide-messages and /restore-messages controls.",
  "type": "module",
  "main": "./index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "config.json",
    "config/config.example.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.json --noCheck",
    "lint": "npm run build",
    "test:clean": "node -e \"require('node:fs').rmSync('.test-dist', { recursive: true, force: true })\"",
    "pretest": "npm run test:clean",
    "test": "npx --yes -p typescript@5.7.3 tsc -p tsconfig.test.json && node --test .test-dist/test/*.test.js",
    "posttest": "npm run test:clean",
    "check": "npm run lint && npm run test"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pi-coding-agent",
    "pi-tui",
    "coding-agent",
    "hide-messages",
    "restore-messages",
    "chat-history",
    "conversation-history",
    "session-context",
    "context-window",
    "tui",
    "messages",
    "privacy"
  ],
  "author": "MasuRii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MasuRii/pi-hide-messages.git"
  },
  "bugs": {
    "url": "https://github.com/MasuRii/pi-hide-messages/issues"
  },
  "homepage": "https://github.com/MasuRii/pi-hide-messages#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@mariozechner/pi-tui": "^0.64.0"
  }
}
