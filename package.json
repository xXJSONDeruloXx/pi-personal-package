{
  "name": "pi-personal-package",
  "private": true,
  "version": "0.3.0",
  "description": "Dan's personal Pi distro for non-work machines",
  "keywords": [
    "pi-package",
    "pi",
    "personal"
  ],
  "type": "module",
  "files": [
    "extensions/",
    "extras/",
    "prompts/",
    "skills/",
    "README.md"
  ],
  "dependencies": {
    "@0xkobold/pi-autoupdate": "^0.1.0",
    "@aliou/pi-processes": "^0.7.0",
    "@ifi/pi-extension-subagents": "^0.4.4",
    "@tmustier/pi-files-widget": "^0.1.15",
    "latchkey": "^2.5.5",
    "pi-extensions": "git+https://github.com/xXJSONDeruloXx/pi-extensions-ralph.git#5a9439a78f26715f34b2d1e447727da1a96c4957",
    "pi-codex-web-search": "^0.1.5",
    "pi-command-center": "^0.1.4",
    "pi-continuous-learning": "^0.9.0",
    "pi-hide-messages": "^0.1.1",
    "pi-interactive-shell": "^0.10.1",
    "pi-stash": "^0.2.0",
    "pi-tool-display": "^0.3.1",
    "yaml": "^2.8.1"
  },
  "bundledDependencies": [
    "@0xkobold/pi-autoupdate",
    "@aliou/pi-processes",
    "@ifi/pi-extension-subagents",
    "@tmustier/pi-files-widget",
    "latchkey",
    "pi-extensions",
    "pi-codex-web-search",
    "pi-command-center",
    "pi-continuous-learning",
    "pi-hide-messages",
    "pi-interactive-shell",
    "pi-stash",
    "pi-tool-display"
  ],
  "pi": {
    "prompts": [
      "./prompts"
    ],
    "extensions": [
      "./extensions",
      "./node_modules/@0xkobold/pi-autoupdate/index.ts",
      "./node_modules/@aliou/pi-processes/src/index.ts",
      "./extensions/codex-usage-widget.ts",
      "./node_modules/@ifi/pi-extension-subagents/index.ts",
      "./node_modules/@ifi/pi-extension-subagents/notify.ts",
      "./node_modules/@tmustier/pi-files-widget/index.ts",
      "./node_modules/pi-extensions/pi-ralph-wiggum/index.ts",
      "./node_modules/pi-codex-web-search/src/index.ts",
      "./node_modules/pi-command-center/extensions/command-center/index.ts",
      "./node_modules/pi-continuous-learning/dist/index.js",
      "./node_modules/pi-hide-messages/index.ts",
      "./node_modules/pi-interactive-shell/index.ts",
      "./extensions/poe-provider/index.ts",
      "./node_modules/pi-stash/src/stash.ts",
      "./node_modules/pi-tool-display/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/@aliou/pi-processes/skills/pi-processes",
      "./node_modules/latchkey/dist/skills/generic",
      "./node_modules/pi-interactive-shell/SKILL.md",
      "./node_modules/pi-interactive-shell/examples/skills"
    ]
  },
  "scripts": {
    "check": "python3 -m py_compile skills/pr-review-watch/scripts/pr_review_watch.py",
    "test": "vitest run extensions/poe-provider/",
    "test:watch": "vitest extensions/poe-provider/"
  },
  "bundleDependencies": [
    "@0xkobold/pi-autoupdate",
    "@aliou/pi-processes",
    "@ifi/pi-extension-subagents",
    "@tmustier/pi-files-widget",
    "latchkey",
    "pi-extensions",
    "pi-codex-web-search",
    "pi-command-center",
    "pi-continuous-learning",
    "pi-hide-messages",
    "pi-interactive-shell",
    "pi-stash",
    "pi-tool-display"
  ],
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
